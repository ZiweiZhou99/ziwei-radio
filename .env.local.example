# 网易云配置
NETEASE_COOKIE=MUSIC_U=your_music_u_cookie_here
NETEASE_USER_ID=your_netease_user_id
# 可选：自建 NeteaseCloudMusicApi 实例（推荐）
NETEASE_API_BASE=http://localhost:3001

# AI API（用于歌曲介绍 + DJ 对话）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# TTS 声音（edge-tts 支持的声音）
# 中文男声选项：zh-CN-YunxiNeural（推荐）, zh-CN-YunjianNeural
# 中文女声选项：zh-CN-XiaoxiaoNeural, zh-CN-XiaoyiNeural
EDGE_TTS_VOICE=zh-CN-YunxiNeural

# Next.js
NEXTAUTH_URL=https://zhouziwei.online
